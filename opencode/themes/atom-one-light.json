{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "white": "#FAFAFA",
    "black": "#383A42",
    "gray1": "#A0A1A7",
    "gray2": "#C2C2C2",
    "gray3": "#D6D6D6",
    "gray4": "#E5E5E6",
    "gray5": "#EAEAEB",
    "gray6": "#F0F0F1",
    "blue": "#4078F2",
